{
  "name": "kaizen",
  "version": "0.1.0",
  "description": "Platform for LLM harnesses",
  "type": "module",
  "module": "src/cli.ts",
  "exports": {
    "./types": "./src/types/plugin.ts"
  },
  "scripts": {
    "build": "bun build --compile --target=bun-linux-x64 ./src/cli.ts --outfile kaizen",
    "build:all": "scripts/build-all.sh",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "test:integration": "bun test --integration",
    "smoke": "scripts/smoke-install.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/openai": "^3.0.50",
    "ai": "^6.0.146",
    "ajv": "^8.18.0",
    "yaml": "^2.8.3"
  }
}
