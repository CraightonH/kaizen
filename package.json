{
  "name": "kaizen",
  "version": "0.1.0",
  "description": "Platform for LLM harnesses",
  "type": "module",
  "module": "src/cli.ts",
  "scripts": {
    "build": "bun build --compile --target=bun-linux-x64 ./src/cli.ts --outfile kaizen",
    "build:all": "scripts/build-all.sh",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "test:integration": "bun test --integration",
    "spike": "bun build --compile src/spike/loader-probe.ts --outfile /tmp/kaizen-probe && echo 'Binary built — running probe...' && /tmp/kaizen-probe"
  },
  "workspaces": [
    "plugins/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "core-lifecycle": "workspace:*",
    "core-ui-terminal": "workspace:*",
    "core-cli": "workspace:*"
  }
}
